{
  "schema_version": "2.0",
  "name": "inventory",
  "version": "2.0.0",
  "type": "gameplay",
  "required": false,
  "description": "Item and equipment management system for RPG gameplay.",
  "dependencies": ["character", "core-blocks"],
  "prompt": {
    "position": "pre-response",
    "priority": 76,
    "template": "prompts/inventory-instruction.md"
  },
  "capabilities": {
    "inventory.use_item": {
      "description": "使用消耗品或装备物品，计算效果并返回结果",
      "implementation": {
        "type": "script",
        "script": "scripts/use_item.py",
        "timeout_ms": 5000
      },
      "result_block_type": "item_effect"
    }
  },
  "blocks": {
    "item_update": {
      "instruction": "When a character gains, loses, uses, equips, or unequips an item, output:\n```json:item_update\n{\"action\": \"gain\", \"item_name\": \"Health Potion\", \"quantity\": 1, \"item_type\": \"consumable\", \"description\": \"A red potion that restores HP.\", \"stats\": {\"hp\": 20}}\n```\nValid actions: gain, lose, use, equip, unequip.\nValid item_type: weapon, armor, consumable, quest, misc.\nstats is optional, used for items with stat effects.",
      "schema": {
        "type": "object",
        "properties": {
          "action": { "type": "string", "enum": ["gain", "lose", "use", "equip", "unequip"] },
          "item_name": { "type": "string" },
          "quantity": { "type": "integer" },
          "item_type": { "type": "string", "enum": ["weapon", "armor", "consumable", "quest", "misc"] },
          "description": { "type": "string" },
          "stats": { "type": "object" }
        },
        "required": ["action", "item_name", "quantity", "item_type"]
      },
      "handler": {
        "actions": [
          { "type": "storage_write", "key": "inventory" },
          { "type": "emit_event", "event": "item-gained" }
        ]
      },
      "ui": {
        "component": "card",
        "title": "{{ action }} — {{ item_name }}",
        "sections": [
          { "type": "key-value", "fields": ["item_name", "quantity", "item_type", "description"] }
        ]
      },
      "requires_response": false
    },
    "loot": {
      "instruction": "After combat or exploration when items are found, output:\n```json:loot\n{\"source\": \"Goblin Camp Chest\", \"items\": [{\"name\": \"Iron Sword\", \"type\": \"weapon\", \"quantity\": 1, \"rarity\": \"uncommon\", \"description\": \"A sturdy blade.\"}], \"gold\": 50}\n```\nrarity values: common, uncommon, rare, epic, legendary.",
      "schema": {
        "type": "object",
        "properties": {
          "source": { "type": "string" },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "quantity": { "type": "integer" },
                "rarity": { "type": "string", "enum": ["common", "uncommon", "rare", "epic", "legendary"] },
                "description": { "type": "string" }
              },
              "required": ["name", "type", "quantity", "rarity"]
            }
          },
          "gold": { "type": "number" }
        },
        "required": ["source", "items"]
      },
      "handler": {
        "actions": [
          { "type": "storage_write", "key": "inventory" },
          { "type": "emit_event", "event": "item-gained" }
        ]
      },
      "ui": {
        "component": "custom",
        "renderer_name": "loot"
      },
      "requires_response": false
    }
  },
  "events": {
    "emit": ["item-gained", "item-used"],
    "listen": []
  },
  "storage": {
    "keys": ["inventory", "item-catalog", "equipment-slots"]
  },
  "permissions": {
    "network": false,
    "filesystem_scope": ["plugin", "data"],
    "script_languages": ["python"]
  },
  "extensions": {
    "runtime_settings": {
      "settings": [
        {
          "key": "loot_frequency",
          "type": "enum",
          "label": "Loot Frequency",
          "description": "How often loot drops appear.",
          "default": "normal",
          "options": [
            {
              "value": "scarce",
              "label": "Scarce",
              "i18n": { "zh": { "label": "稀少" } }
            },
            {
              "value": "normal",
              "label": "Normal",
              "i18n": { "zh": { "label": "正常" } }
            },
            {
              "value": "abundant",
              "label": "Abundant",
              "i18n": { "zh": { "label": "丰富" } }
            }
          ],
          "affects": ["loot"],
          "i18n": {
            "zh": {
              "label": "掉落频率",
              "description": "战利品掉落的频率。"
            }
          }
        },
        {
          "key": "show_item_stats",
          "type": "enum",
          "label": "Show Item Stats",
          "description": "Whether to display item stat effects.",
          "default": "visible",
          "options": [
            {
              "value": "hidden",
              "label": "Hidden",
              "i18n": { "zh": { "label": "隐藏" } }
            },
            {
              "value": "visible",
              "label": "Visible",
              "i18n": { "zh": { "label": "显示" } }
            }
          ],
          "affects": ["inventory"],
          "i18n": {
            "zh": {
              "label": "显示物品属性",
              "description": "是否显示物品的属性效果。"
            }
          }
        }
      ]
    }
  },
  "i18n": {
    "en": {
      "name": "Inventory",
      "description": "Item and equipment management system."
    },
    "zh": {
      "name": "物品与装备",
      "description": "物品获取、使用、装备管理系统。"
    }
  }
}
