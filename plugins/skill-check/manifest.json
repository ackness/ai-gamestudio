{
  "schema_version": "2.0",
  "name": "skill-check",
  "version": "2.0.0",
  "type": "gameplay",
  "required": false,
  "description": "Skill check system: resolves ability/skill checks against difficulty class.",
  "dependencies": ["dice-roll", "character", "core-blocks"],
  "prompt": {
    "position": "pre-response",
    "priority": 72,
    "template": "prompts/skill-check-instruction.md"
  },
  "capabilities": {
    "skill_check.resolve": {
      "description": "执行技能检定：掷 1d20 + 修正值，与难度等级比较",
      "implementation": {
        "type": "script",
        "script": "scripts/resolve.py",
        "timeout_ms": 5000
      },
      "result_block_type": "skill_check_result"
    }
  },
  "blocks": {
    "skill_check": {
      "instruction": "当玩家尝试需要技能检定的行动时（如潜行、说服、攀爬、开锁等），输出 json:skill_check block 请求检定。格式：\n```json:skill_check\n{\"skill\": \"stealth\", \"difficulty\": 15, \"modifier\": 3, \"attribute_bonus\": 2, \"description\": \"尝试潜行通过守卫\"}\n```\n必需字段：skill, difficulty。可选字段：modifier, attribute_bonus, description。",
      "schema": {
        "type": "object",
        "properties": {
          "skill": { "type": "string" },
          "difficulty": { "type": "integer" },
          "modifier": { "type": "integer" },
          "attribute_bonus": { "type": "integer" },
          "description": { "type": "string" }
        },
        "required": ["skill", "difficulty"]
      },
      "handler": {
        "actions": []
      },
      "ui": {
        "component": "none"
      },
      "requires_response": false
    },
    "skill_check_result": {
      "instruction": "此 block 由系统自动生成，不要手动输出。",
      "schema": {
        "type": "object",
        "properties": {
          "dice": { "type": "string" },
          "roll": { "type": "integer" },
          "modifier": { "type": "integer" },
          "attribute_bonus": { "type": "integer" },
          "total": { "type": "integer" },
          "difficulty": { "type": "integer" },
          "success_level": { "type": "string", "enum": ["critical_success", "success", "failure", "critical_failure"] },
          "skill": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["dice", "roll", "total", "difficulty", "success_level"]
      },
      "handler": {
        "actions": [
          { "type": "storage_write", "key": "last-check" },
          { "type": "emit_event", "event": "skill-checked" }
        ]
      },
      "ui": {
        "component": "custom",
        "renderer_name": "skill_check_result"
      },
      "requires_response": false
    }
  },
  "events": {
    "emit": ["skill-checked"],
    "listen": []
  },
  "storage": {
    "keys": ["last-check"]
  },
  "permissions": {
    "network": false,
    "filesystem_scope": ["plugin", "data"],
    "script_languages": ["python"]
  },
  "extensions": {},
  "i18n": {
    "en": {
      "name": "Skill Check",
      "description": "Skill check system: resolves ability/skill checks against difficulty class."
    },
    "zh": {
      "name": "技能检定",
      "description": "技能检定系统：执行能力/技能检定并与难度等级比较。"
    }
  }
}
