{
  "schema_version": "1.0",
  "version": "0.1.0",
  "name": "state",
  "type": "global",
  "required": true,
  "supersedes": [
    "character"
  ],
  "description": "Core state management: state sync, character sheets, scene updates, and character context injection.",
  "dependencies": [
    "database"
  ],
  "prompt": {
    "position": "character",
    "priority": 10,
    "template": "prompts/state-context.md"
  },
  "capabilities": {},
  "outputs": {
    "state_update": {
      "instruction": "在角色属性、物品或世界状态发生真实变化时，调用 `emit`，在 `items` 中加入 `{\"type\":\"state_update\",\"data\":{...}}`。`data` 必须是对象，且至少包含 `characters` 或 `world` 之一，只传本回合增量。",
      "instruction_file": "prompts/agent/outputs/state_update.md",
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "characters": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "character_id": {
                  "type": "string",
                  "minLength": 1
                },
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "role": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "personality": {
                  "type": "string"
                },
                "attributes": {
                  "type": "object"
                },
                "inventory": {
                  "type": "array"
                }
              }
            }
          },
          "world": {
            "type": "object",
            "properties": {
              "_delete": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": true
          }
        }
      },
      "handler": {
        "actions": [
          {
            "type": "builtin",
            "handler_name": "state_update"
          }
        ]
      },
      "ui": {
        "component": "none"
      },
      "requires_response": false
    },
    "character_sheet": {
      "instruction": "仅在角色创建或重建阶段调用 `emit`，在 `items` 中加入 `{\"type\":\"character_sheet\",\"data\":{...}}`。`data.name` 必填；创建新角色时使用 `character_id: \"new\"`。",
      "instruction_file": "prompts/agent/outputs/character_sheet.md",
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "character_id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "editable_fields": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "attributes": {
            "type": "object"
          },
          "inventory": {
            "type": "array"
          },
          "description": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "background": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "handler": {
        "actions": [
          {
            "type": "builtin",
            "handler_name": "character_sheet"
          }
        ]
      },
      "ui": {
        "component": "custom",
        "renderer_name": "character_sheet"
      },
      "requires_response": false,
      "trigger": {
        "mode": "once_per_session"
      }
    },
    "scene_update": {
      "instruction": "当玩家切换地点或当前场景发生变化时，调用 `emit` 输出 `scene_update`。若 `action` 为 `move`，必须提供 `name`。",
      "instruction_file": "prompts/agent/outputs/scene_update.md",
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "move",
              "update"
            ]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "scene_id": {
            "type": "string"
          },
          "npcs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "character_id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "character_name": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "role_in_scene": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "handler": {
        "actions": [
          {
            "type": "builtin",
            "handler_name": "scene_update"
          }
        ]
      },
      "ui": {
        "component": "custom",
        "renderer_name": "scene_update"
      },
      "requires_response": false
    },
    "notification": {
      "instruction": "当需要给玩家提示、警告或奖励反馈时，调用 `emit` 输出 `notification`。`data.content` 必填，`level` 使用 `info/warning/success/error`。",
      "instruction_file": "prompts/agent/outputs/notification.md",
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "level": {
            "type": "string",
            "enum": [
              "info",
              "warning",
              "success",
              "error"
            ]
          },
          "title": {
            "type": "string",
            "maxLength": 80
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          }
        },
        "required": [
          "content"
        ]
      },
      "ui": {
        "component": "custom",
        "renderer_name": "notification"
      },
      "requires_response": false
    }
  },
  "events": {
    "emit": [],
    "listen": []
  },
  "storage": {
    "keys": [
      "characters",
      "character-templates",
      "inventories"
    ]
  },
  "extensions": {
    "agent_prompt": {
      "base_file": "prompts/agent/base.md",
      "output_files": {
        "state_update": "prompts/agent/outputs/state_update.md",
        "character_sheet": "prompts/agent/outputs/character_sheet.md",
        "scene_update": "prompts/agent/outputs/scene_update.md",
        "notification": "prompts/agent/outputs/notification.md"
      },
      "tool_files": {
        "emit": "prompts/agent/tools/emit.md"
      }
    },
    "runtime_settings": {
      "fields": {
        "narrative_tone": {
          "type": "enum",
          "label": "Narrative Tone",
          "description": "Preferred tone for DM narration.",
          "default": "neutral",
          "options": [
            {
              "value": "neutral",
              "label": "Neutral",
              "i18n": {
                "zh": {
                  "label": "中立"
                }
              }
            },
            {
              "value": "grim",
              "label": "Grim",
              "i18n": {
                "zh": {
                  "label": "阴暗"
                }
              }
            },
            {
              "value": "heroic",
              "label": "Heroic",
              "i18n": {
                "zh": {
                  "label": "史诗"
                }
              }
            },
            {
              "value": "whimsical",
              "label": "Whimsical",
              "i18n": {
                "zh": {
                  "label": "奇幻轻松"
                }
              }
            }
          ],
          "affects": [
            "story"
          ],
          "i18n": {
            "zh": {
              "label": "叙事基调",
              "description": "DM 叙事的偏好基调。"
            }
          }
        },
        "pacing": {
          "type": "enum",
          "label": "Narrative Pacing",
          "description": "Controls how quickly scenes and events progress.",
          "default": "balanced",
          "options": [
            {
              "value": "slow",
              "label": "Slow",
              "i18n": {
                "zh": {
                  "label": "舒缓"
                }
              }
            },
            {
              "value": "balanced",
              "label": "Balanced",
              "i18n": {
                "zh": {
                  "label": "均衡"
                }
              }
            },
            {
              "value": "fast",
              "label": "Fast",
              "i18n": {
                "zh": {
                  "label": "紧凑"
                }
              }
            }
          ],
          "affects": [
            "story",
            "choices"
          ],
          "i18n": {
            "zh": {
              "label": "叙事节奏",
              "description": "控制场景和事件推进的速度。"
            }
          }
        },
        "response_length": {
          "type": "enum",
          "label": "Narration Length",
          "description": "Desired average response length.",
          "default": "medium",
          "options": [
            {
              "value": "short",
              "label": "Short",
              "i18n": {
                "zh": {
                  "label": "简短"
                }
              }
            },
            {
              "value": "medium",
              "label": "Medium",
              "i18n": {
                "zh": {
                  "label": "适中"
                }
              }
            },
            {
              "value": "long",
              "label": "Long",
              "i18n": {
                "zh": {
                  "label": "详尽"
                }
              }
            }
          ],
          "affects": [
            "story"
          ],
          "i18n": {
            "zh": {
              "label": "叙述长度",
              "description": "期望的平均回复长度。"
            }
          }
        },
        "risk_bias": {
          "type": "enum",
          "label": "Story Risk Bias",
          "description": "Whether events should trend safer or more dangerous.",
          "default": "balanced",
          "options": [
            {
              "value": "safe",
              "label": "Safe",
              "i18n": {
                "zh": {
                  "label": "安全"
                }
              }
            },
            {
              "value": "balanced",
              "label": "Balanced",
              "i18n": {
                "zh": {
                  "label": "均衡"
                }
              }
            },
            {
              "value": "dangerous",
              "label": "Dangerous",
              "i18n": {
                "zh": {
                  "label": "危险"
                }
              }
            }
          ],
          "affects": [
            "story",
            "choices"
          ],
          "i18n": {
            "zh": {
              "label": "故事风险倾向",
              "description": "事件走向偏安全还是偏危险。"
            }
          }
        }
      }
    }
  },
  "i18n": {
    "en": {
      "name": "State",
      "description": "Core state management: state sync, character sheets, scene updates, and character context."
    },
    "zh": {
      "name": "状态管理",
      "description": "核心状态管理：状态同步、角色卡、场景更新与角色上下文注入。"
    }
  }
}
