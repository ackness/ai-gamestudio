{
  "schema_version": "2.0",
  "name": "quest",
  "version": "2.0.0",
  "type": "gameplay",
  "required": false,
  "description": "Quest tracking system for creating, updating, and completing quests.",
  "dependencies": ["database", "core-blocks"],
  "prompt": {
    "position": "world-state",
    "priority": 60,
    "template": "prompts/quest-context.md"
  },
  "capabilities": {},
  "blocks": {
    "quest_update": {
      "instruction": "When creating, updating, completing, or failing a quest, output:\n```json:quest_update\n{\"action\": \"create\", \"quest_id\": \"find-artifact\", \"title\": \"Find the Lost Artifact\", \"description\": \"Locate the ancient artifact in the ruins.\", \"objectives\": [{\"id\": \"obj1\", \"text\": \"Enter the ruins\", \"completed\": false}], \"rewards\": {\"xp\": 100, \"gold\": 50}, \"status\": \"active\"}\n```\nValid actions: create, update, complete, fail.\nValid status: active, completed, failed.",
      "schema": {
        "type": "object",
        "properties": {
          "action": { "type": "string", "enum": ["create", "update", "complete", "fail"] },
          "quest_id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "objectives": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "text": { "type": "string" },
                "completed": { "type": "boolean" }
              },
              "required": ["id", "text", "completed"]
            }
          },
          "rewards": {
            "type": "object",
            "properties": {
              "xp": { "type": "number" },
              "gold": { "type": "number" },
              "items": { "type": "array", "items": { "type": "string" } }
            }
          },
          "status": { "type": "string", "enum": ["active", "completed", "failed"] }
        },
        "required": ["action", "quest_id", "title", "status"]
      },
      "handler": {
        "actions": [
          { "type": "storage_write", "key": "active-quests" },
          { "type": "emit_event", "event": "quest-created" }
        ]
      },
      "ui": {
        "component": "custom",
        "renderer_name": "quest_update"
      },
      "requires_response": false
    }
  },
  "events": {
    "emit": ["quest-created", "quest-completed"],
    "listen": []
  },
  "storage": {
    "keys": ["active-quests", "completed-quests"]
  },
  "permissions": {
    "network": false,
    "filesystem_scope": ["plugin", "data"],
    "script_languages": []
  },
  "extensions": {
    "runtime_settings": {
      "settings": [
        {
          "key": "quest_complexity",
          "type": "enum",
          "label": "Quest Complexity",
          "description": "How complex generated quests should be.",
          "default": "standard",
          "options": [
            {
              "value": "simple",
              "label": "Simple",
              "i18n": { "zh": { "label": "简单" } }
            },
            {
              "value": "standard",
              "label": "Standard",
              "i18n": { "zh": { "label": "标准" } }
            },
            {
              "value": "complex",
              "label": "Complex",
              "i18n": { "zh": { "label": "复杂" } }
            }
          ],
          "affects": ["quest"],
          "i18n": {
            "zh": {
              "label": "任务复杂度",
              "description": "生成任务的复杂程度。"
            }
          }
        },
        {
          "key": "show_rewards",
          "type": "enum",
          "label": "Show Rewards",
          "description": "Whether to preview quest rewards before completion.",
          "default": "preview",
          "options": [
            {
              "value": "hidden",
              "label": "Hidden",
              "i18n": { "zh": { "label": "隐藏" } }
            },
            {
              "value": "preview",
              "label": "Preview",
              "i18n": { "zh": { "label": "预览" } }
            }
          ],
          "affects": ["quest"],
          "i18n": {
            "zh": {
              "label": "显示奖励",
              "description": "是否在任务完成前预览奖励。"
            }
          }
        }
      ]
    }
  },
  "i18n": {
    "en": {
      "name": "Quest System",
      "description": "Quest tracking and management system."
    },
    "zh": {
      "name": "任务系统",
      "description": "任务追踪与管理系统。"
    }
  }
}
