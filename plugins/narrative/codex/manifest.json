{
  "schema_version": "1.0",
  "version": "0.1.0",
  "name": "codex",
  "type": "gameplay",
  "required": false,
  "description": "Codex/encyclopedia plugin that tracks discovered knowledge entries across categories.",
  "dependencies": [
    "database"
  ],
  "prompt": {
    "position": "memory",
    "priority": 40,
    "template": "prompts/codex-context.md"
  },
  "capabilities": {},
  "outputs": {
    "codex_entry": {
      "instruction": "当玩家获得新知识时，用 `emit.items` 输出 `codex_entry`。`action` 为 `unlock/update`；`category` 为 `monster/item/location/lore/character`。避免重复记录已知条目。",
      "schema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "unlock",
              "update"
            ]
          },
          "category": {
            "type": "string",
            "enum": [
              "monster",
              "item",
              "location",
              "lore",
              "character"
            ]
          },
          "entry_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "image_hint": {
            "type": "string"
          }
        },
        "required": [
          "action",
          "category",
          "entry_id",
          "title",
          "content"
        ]
      },
      "handler": {
        "actions": [
          {
            "type": "storage_list_upsert",
            "key": "codex-entries",
            "match_field": "entry_id"
          },
          {
            "type": "emit_event",
            "event": "codex-unlocked"
          }
        ]
      },
      "ui": {
        "component": "custom",
        "renderer_name": "codex_entry"
      },
      "requires_response": false
    }
  },
  "events": {
    "emit": [
      "codex-unlocked"
    ],
    "listen": []
  },
  "storage": {
    "collections": {
      "codex-entries": { "type": "kv", "scope": "session" }
    }
  },
  "extensions": {
    "runtime_settings": {
      "fields": {
        "codex_detail": {
          "type": "enum",
          "label": "Codex Detail Level",
          "description": "Level of detail in codex entry descriptions.",
          "default": "detailed",
          "options": [
            {
              "value": "brief",
              "label": "Brief",
              "i18n": {
                "zh": {
                  "label": "简要"
                }
              }
            },
            {
              "value": "detailed",
              "label": "Detailed",
              "i18n": {
                "zh": {
                  "label": "详细"
                }
              }
            }
          ],
          "affects": [
            "story"
          ],
          "i18n": {
            "zh": {
              "label": "图鉴详细度",
              "description": "图鉴条目描述的详细程度。"
            }
          }
        }
      }
    }
  },
  "i18n": {
    "en": {
      "name": "Codex",
      "description": "Track discovered knowledge entries including monsters, items, locations, lore, and characters."
    },
    "zh": {
      "name": "图鉴百科",
      "description": "记录玩家发现的知识条目，包括怪物、物品、地点、传说与角色。"
    }
  }
}
