# LLM Configuration
# 默认模型（LiteLLM 格式: provider/model）
# DeepSeek：1M 上下文、工具调用稳定、价格实惠，推荐作为默认模型
LLM_MODEL=deepseek/deepseek-chat
LLM_API_KEY=your-deepseek-key
LLM_API_BASE=https://api.deepseek.com

# --- OpenAI 配置示例 ---
# LLM_MODEL=gpt-5-mini-2025-08-07
# LLM_API_KEY=your-openai-key
# LLM_API_BASE=          # 留空使用默认 OpenAI 端点

# --- OpenRouter 配置示例 ---
# LLM_MODEL=openrouter/deepseek/deepseek-chat
# LLM_API_KEY=your-openrouter-key
# LLM_API_BASE=https://openrouter.ai/api/v1

# --- 插件模型配置（可选，留空则与主模型相同） ---
# 可使用更小/更快的模型来加速插件决策，如本地 Ollama
# PLUGIN_LLM_MODEL=openai/llama3.2
# PLUGIN_LLM_API_KEY=ollama
# PLUGIN_LLM_API_BASE=http://localhost:11434/v1

# --- ImageGen 配置示例 ---
IMAGE_GEN_MODEL=gemini-2.5-flash-image-preview
IMAGE_GEN_API_KEY=
# IMAGE_GEN_API_BASE=   # 留空使用模型提供商默认端点

# Database
# Local dev (default): sqlite+aiosqlite:///data/db.sqlite
# Vercel production: use postgres, e.g. postgresql+asyncpg://<user>:<pass>@<host>/<db>
DATABASE_URL=sqlite+aiosqlite:///data/db.sqlite

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Plugins directory
PLUGINS_DIR=plugins

# Secret store directory (stores API keys by reference, outside DB rows)
SECRET_STORE_DIR=data/secrets

# Optional override for trusted api_base hosts (comma-separated or JSON array).
# Defaults already include:
# - api.openai.com
# - openrouter.ai
# - api.deepseek.com
# - api.anthropic.com
# - dashscope.aliyuncs.com
# API_BASE_ALLOWED_HOSTS=api.openai.com,openrouter.ai

# Access key (optional — protects API endpoints when set)
# ACCESS_KEY=your-secret-key
# WARNING: VITE_ACCESS_KEY is embedded in the frontend bundle and visible to
# end users via browser DevTools. It provides only basic access gating, NOT
# true authentication. Do not rely on it for security-sensitive deployments.
# VITE_ACCESS_KEY=your-secret-key
