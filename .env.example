# LLM Configuration
# 默认模型（LiteLLM 格式: provider/model）
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your-api-key-here
# LLM_API_BASE=          # Optional: custom API base URL

# --- DeepSeek 配置示例 ---
# LLM_MODEL=deepseek/deepseek-chat
# LLM_API_KEY=your-deepseek-key
# LLM_API_BASE=https://api.deepseek.com

# --- OpenRouter 配置示例 ---
# LLM_MODEL=openrouter/deepseek/deepseek-chat
# LLM_API_KEY=your-openrouter-key
# LLM_API_BASE=https://openrouter.ai/api/v1

# --- ImageGen 配置示例 ---
IMAGE_GEN_MODEL=gemini-2.5-flash-image-preview
IMAGE_GEN_API_KEY=
IMAGE_GEN_API_BASE=https://api.whatai.cc/v1/chat/completions

# Database
DATABASE_URL=sqlite+aiosqlite:///data/db.sqlite

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:5173"]

# Plugins directory
PLUGINS_DIR=plugins

# Secret store directory (stores API keys by reference, outside DB rows)
SECRET_STORE_DIR=data/secrets
